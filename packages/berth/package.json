{
  "name": "@color-sunset/berth",
  "version": "0.1.0",
  "type": "module",
  "description": "A toolkit that turns cooperating AI coding agents into a disciplined, parallel-safe, review-gated development workflow.",
  "license": "MIT",
  "bin": {
    "berth": "./dist/cli.js"
  },
  "files": [
    "dist",
    "scripts",
    "adapters",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/RemyFevry/agentic-tools.git",
    "directory": "packages/berth"
  },
  "homepage": "https://github.com/RemyFevry/agentic-tools/tree/main/packages/berth#readme",
  "bugs": {
    "url": "https://github.com/RemyFevry/agentic-tools/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "agent",
    "ai-agents",
    "claude-code",
    "opencode",
    "pi",
    "worktree",
    "guard",
    "orchestrator",
    "herdr"
  ],
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "pnpm lint && pnpm build && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "lefthook": "^1.13.6",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.2.7"
  }
}
