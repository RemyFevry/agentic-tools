{
  "_comments": {
    "name": "The published npm name is undecided; 'berth' is provisional. This package is private and is not configured for publishing."
  },
  "name": "berth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A toolkit that turns cooperating AI coding agents into a disciplined, parallel-safe, review-gated development workflow.",
  "license": "MIT",
  "bin": {
    "berth": "./dist/cli.js"
  },
  "keywords": [
    "ai",
    "agents",
    "workflow",
    "git",
    "worktree",
    "guard",
    "trunk"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "pnpm lint && pnpm build && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "lefthook": "^1.13.6",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.2.7"
  }
}
